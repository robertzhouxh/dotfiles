#!/usr/bin/env bash

export EDITOR='vim'
export LANG='en_US.UTF-8'
export LC_ALL='en_US.UTF-8'
[[ -t 0 ]] && export GPG_TTY=$(tty)

# Homebrew (macOS / Linux)
if [[ -x "/opt/homebrew/bin/brew" ]]; then
    eval "$(/opt/homebrew/bin/brew shellenv)"
elif [[ -x "/usr/local/bin/brew" ]]; then
    eval "$(/usr/local/bin/brew shellenv)"
fi

# asdf (优先 Git 安装，其次 brew)
if [[ -f "$HOME/.asdf/asdf.sh" ]]; then
    source "$HOME/.asdf/asdf.sh"
elif command -v brew &>/dev/null && brew --prefix asdf &>/dev/null 2>&1; then
    source "$(brew --prefix asdf)/libexec/asdf.sh"
fi

# macOS 专用: JDK + OpenSSL 编译参数
if [[ "$(uname -s)" == "Darwin" ]] && command -v brew &>/dev/null; then
    readonly BREW_PREFIX="$(brew --prefix)"
    [[ -d "$BREW_PREFIX/opt/openjdk" ]] && {
        export JAVA_HOME="$BREW_PREFIX/opt/openjdk"
        export PATH="$JAVA_HOME/bin:$PATH"
    }
    [[ -d "$BREW_PREFIX/opt/openssl@3" ]] && {
        export LDFLAGS="-L${BREW_PREFIX}/opt/openssl@3/lib"
        export CPPFLAGS="-I${BREW_PREFIX}/opt/openssl@3/include"
    }
fi

command -v go &>/dev/null && [[ -z "$GOPATH" ]] && {
    export GOPATH="$HOME/go"
    export GOBIN="$GOPATH/bin"
    export GOPROXY="https://goproxy.cn,direct"
    export PATH="$GOBIN:$PATH"
}
[[ -f "$HOME/.cargo/env" ]] && source "$HOME/.cargo/env"
[[ -d "$HOME/.npm-global/bin" ]] && export PATH="$HOME/.npm-global/bin:$PATH"
[[ -d "$HOME/claude-model/bin" ]] && export PATH="$HOME/claude-model/bin:$PATH"

# Conda (保留功能但默认不激活 base)
[[ -f "$HOME/miniconda3/etc/profile.d/conda.sh" ]] && source "$HOME/miniconda3/etc/profile.d/conda.sh"
