#!/usr/bin/env bash

export EDITOR='vim'
export LANG='en_US.UTF-8'
export LC_ALL='en_US.UTF-8'
export GPG_TTY=$(tty)

## GoogleAIStudioToken:
## OpenRouterToken: openrouter/google/gemini-2.5-pro-exp-03-25:free
## OPENROUTER_API_KEY=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
export GOOGLE_CLOUD_PROJECT=gen-lang-client-0720396680
export GEMINI_API_KEY=AIzaSyCavqY3jyhRiR1n1jDPzKUDB2iyGhKMosA
export GEMINI_MODEL=gemini-2.5-pro
export GOOGLE_GEMINI_BASE_URL=http://localhost:3434

# Add these lines to the file:
export OPENROUTER_API_KEY="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"
export ANTHROPIC_BASE_URL="https://openrouter.ai/api"
export ANTHROPIC_AUTH_TOKEN="$OPENROUTER_API_KEY"
export ANTHROPIC_API_KEY="" # Important: Must be explicitly empty
# After saving, restart your terminal for changes to take effect


# homebrew 初始化
if [ -x "/opt/homebrew/bin/brew" ]; then
  eval "$(/opt/homebrew/bin/brew shellenv)"
elif [ -x "/usr/local/bin/brew" ]; then
  eval "$(/usr/local/bin/brew shellenv)"
fi

# asdf 初始化
. "$(brew --prefix asdf)/libexec/asdf.sh"

# Java && openssl
if [[ "$(uname -s)" == "Darwin" ]]; then
  if command -v brew &>/dev/null; then
    export BREW_PREFIX="$(brew --prefix)"
    # JDK（openjdk）路径配置
    if [[ -d "$BREW_PREFIX/opt/openjdk" ]]; then
      export JAVA_HOME="$BREW_PREFIX/opt/openjdk"
      export PATH="$PATH:$JAVA_HOME/bin"
    fi
    # OpenSSL 环境变量（用于编译 C/C++ 时）
    export LDFLAGS="-L${BREW_PREFIX}/opt/openssl@3/lib"
    export CPPFLAGS="-I${BREW_PREFIX}/opt/openssl@3/include"
  fi
fi

if command -v asdf &>/dev/null; then
  if asdf list "golang" &>/dev/null; then
    export GOPATH="$HOME/src/go"
    export GOBIN="$GOPATH/bin"
    export GOPROXY="https://goproxy.cn,direct"

    case ":$PATH:" in
      *":$GOBIN:"*) ;;
      *) export PATH="$PATH:$GOBIN" ;;
    esac
  fi
fi

if [ -f "$HOME/.cargo/env" ]; then
  if ! echo "$PATH" | grep -q "$HOME/.cargo/bin"; then
    source "$HOME/.cargo/env"
  fi
fi

export PATH="$HOME/.npm-global/bin:$PATH"
export PATH="$HOME/claude-model/bin:$PATH"
source ~/miniconda3/bin/activate
