#!/usr/bin/env bash

# =========================================================
# 基础环境
if [ -n "$ZSH_VERSION" ]; then
  HISTSIZE=50000
  setopt HIST_IGNORE_ALL_DUPS
  setopt HIST_REDUCE_BLANKS
  setopt SHARE_HISTORY
  setopt EXTENDED_HISTORY
  setopt INTERACTIVE_COMMENTS
  setopt NO_BEEP
fi
if [ -n "$BASH_VERSION" ]; then
  HISTSIZE=50000
  HISTFILESIZE=50000
  shopt -s histappend
  export HISTCONTROL=ignoredups:erasedups
fi
export LANG=en_US.UTF-8
export LC_ALL=en_US.UTF-8
export EDITOR='emacsclient -t'
export VISUAL='emacsclient -c -a emacs'
[ -t 0 ] && export GPG_TTY="$(tty)"

# =========================================================
# API Keys
# vim ~/.config/secrets/env
# export DEEPSEEK_API_KEY='sk-...'
# export OPENROUTER_API_KEY='sk-or-...'
# 权限收紧： chmod 600 ~/.config/secrets/env

[ -r "$HOME/.config/secrets/env" ] && . "$HOME/.config/secrets/env"

# =========================================================
# Homebrew
if command -v brew >/dev/null 2>&1; then
  eval "$(brew shellenv)"
fi

# =========================================================
# 路径去重
_path_prepend() {
  case ":$PATH:" in
    *:"$1":*) ;;
    *) [ -d "$1" ] && export PATH="$1:$PATH" ;;
  esac
}
_path_append() {
  case ":$PATH:" in
    *:"$1":*) ;;
    *) [ -d "$1" ] && export PATH="$PATH:$1" ;;
  esac
}

# =========================================================
# 用户目录
_path_prepend "$HOME/bin"
_path_prepend "$HOME/.local/bin"
_path_prepend "$HOME/.local/share/bin"

# =========================================================
# XDG 基础目录
[ -z "$XDG_CONFIG_HOME" ] && export XDG_CONFIG_HOME="$HOME/.config"
[ -z "$XDG_DATA_HOME"   ] && export XDG_DATA_HOME="$HOME/.local/share"
[ -z "$XDG_CACHE_HOME"  ] && export XDG_CACHE_HOME="$HOME/.cache"
[ -z "$XDG_STATE_HOME"  ] && export XDG_STATE_HOME="$HOME/.local/state"

# =========================================================
# Node.js
_path_prepend "$HOME/.npm-global/bin"

# =========================================================
# Golang
if command -v go >/dev/null 2>&1; then
  export GOPATH="${GOPATH:-$HOME/go}"
  export GOPROXY='https://goproxy.cn,direct'
  _path_prepend "$GOPATH/bin"
  GOROOT="$(asdf where golang 2>/dev/null)"
  [ -n "$GOROOT" ] && export GOROOT
fi

# =========================================================
# Rust
[ -f "$HOME/.cargo/env" ] && . "$HOME/.cargo/env"

# =========================================================
# macOS 工具链
if [ "$(uname -s)" = "Darwin" ] && command -v brew >/dev/null 2>&1; then
  BREW_PREFIX="$(brew --prefix)"
  if [ -d "$BREW_PREFIX/opt/openjdk" ]; then
    export JAVA_HOME="$BREW_PREFIX/opt/openjdk"
    _path_prepend "$JAVA_HOME/bin"
  fi
  if [ -d "$BREW_PREFIX/opt/openssl@3" ]; then
    export LDFLAGS="-L$BREW_PREFIX/opt/openssl@3/lib"
    export CPPFLAGS="-I$BREW_PREFIX/opt/openssl@3/include"
    export PKG_CONFIG_PATH="$BREW_PREFIX/opt/openssl@3/lib/pkgconfig"
  fi
fi

# =========================================================
# asdf
export ASDF_DATA_DIR="$HOME/.asdf"
_path_prepend "$ASDF_DATA_DIR/shims"

unset -f _path_prepend _path_append
